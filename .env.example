COMPOSE_PROJECT_NAME=quant_system

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quant_admin
POSTGRES_PASSWORD=quant_local_password
POSTGRES_DB=quant_system

REDIS_HOST=localhost
REDIS_PORT=6379

QUANT_DATA_HUB_PORT=18000
QUANT_FACTOR_LAB_PORT=18010
QUANT_FACTOR_VALIDATION_PORT=18020
QUANT_OPS_API_PORT=18030
QUANT_OPS_WEB_PORT=18040
QUANT_DATA_HUB_BASE_URL=http://quant_data_hub:8000
QUANT_FACTOR_LAB_BASE_URL=http://quant_factor_lab:8000
QUANT_FACTOR_VALIDATION_BASE_URL=http://quant_factor_validation:8000
QUANT_OPS_API_INTERNAL_URL=http://quant_ops_api:8000
VITE_QUANT_OPS_API_BASE_PATH=/ops-api
QUANT_DATA_API_TOKEN=
QUANT_DATA_HUB_TIMEOUT_SECONDS=15
VALIDATION_PERSISTENCE_ENABLED=false
VALIDATION_DATABASE_URL=postgresql+asyncpg://quant_admin:quant_local_password@postgres:5432/quant_factor_validation
VALIDATION_DATABASE_ECHO=false
VALIDATION_OBJECT_STORE_ENDPOINT=
VALIDATION_OBJECT_STORE_ACCESS_KEY=
VALIDATION_OBJECT_STORE_SECRET_KEY=
VALIDATION_OBJECT_STORE_BUCKET=quant-factor-data
VALIDATION_OBJECT_STORE_SECURE=false
VALIDATION_SMOKE_CREATE_SCHEMA=true
VALIDATION_SMOKE_CREATE_BUCKET=false
VALIDATION_SMOKE_RUN_ID=validation_smoke_local
SERVICE_HEALTH_TIMEOUT_SECONDS=5

CLICKHOUSE_HTTP_URL=http://host.docker.internal:18123
CLICKHOUSE_DATABASE=quant_market
CLICKHOUSE_USER=quant
CLICKHOUSE_PASSWORD=

TZ=Asia/Shanghai
